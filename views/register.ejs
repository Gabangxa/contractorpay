<%- include('partials/header') %>

<div style="max-width: 400px; margin: 60px auto;">
  <h1 style="text-align: center; margin-bottom: 8px;">Create your account</h1>
  <p style="text-align: center; color: #6B7280; margin-bottom: 32px;">Start tracking contractor invoices today</p>

  <div class="form-card">
    <form method="POST" action="/register">
      <div class="form-group">
        <label for="name">Full name</label>
        <input
          type="text"
          id="name"
          name="name"
          required
          autocomplete="name"
          placeholder="Jane Smith"
        >
      </div>

      <div class="form-group">
        <label for="email">Email address</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          autocomplete="email"
          placeholder="you@company.com"
        >
      </div>

      <div class="form-group">
        <label for="password">Password <span style="color: #9CA3AF; font-weight: 400;">(min. 8 characters)</span></label>
        <input
          type="password"
          id="password"
          name="password"
          required
          minlength="8"
          autocomplete="new-password"
          placeholder="••••••••"
        >
      </div>

      <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center;">
        Create Account
      </button>
    </form>

    <p style="text-align: center; margin-top: 20px; font-size: 14px; color: #6B7280;">
      Already have an account? <a href="/login" style="color: #4F46E5;">Log in</a>
    </p>
  </div>
</div>

<%- include('partials/footer') %>
